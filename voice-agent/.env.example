# Copy to voice-agent/.env OR keep vars in repo root .env.local (auto-loaded).



# ─── LiveKit ───────────────────────────────────────────────────────────────────

LIVEKIT_URL=wss://your-project.livekit.cloud

LIVEKIT_API_KEY=

LIVEKIT_API_SECRET=

# Must match backend LIVEKIT_AGENT_NAME for explicit agent dispatch

LIVEKIT_AGENT_NAME=vidhyapika-tutor



# ─── Deepgram (STT + TTS) ──────────────────────────────────────────────────────

DEEPGRAM_API_KEY=



# ─── Gemini (LLM) — GEMINI_API_KEY or GOOGLE_API_KEY ───────────────────────────

GEMINI_API_KEY=



NEXT_APP_URL=http://localhost:3000

VOICE_AGENT_SERVICE_SECRET=change-me-min-16-chars

HF_TOKEN=

